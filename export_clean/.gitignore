# ===========================================
# FitMaxPro - Git Ignore
# ===========================================

# ==================== ENVIRONMENT FILES ====================
# CRITICAL: Never commit these files!
.env
.env.local
.env.development
.env.production
.env*.local
backend/.env
frontend/.env

# ==================== DEPENDENCIES ====================
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
env/
.venv/
ENV/

# ==================== BUILD OUTPUTS ====================
build/
dist/
*.egg-info/
.eggs/
frontend/build/
*.bundle.js
*.bundle.js.map

# ==================== IDE & EDITORS ====================
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project
.project
.settings/
.classpath

# ==================== OS FILES ====================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ==================== LOGS ====================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== TESTING ====================
coverage/
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ==================== UPLOADS (User Content) ====================
backend/uploads/videos/*
!backend/uploads/videos/.gitkeep

# ==================== MOBILE BUILDS ====================
android/
ios/
*.apk
*.ipa
*.aab

# ==================== MISC ====================
*.zip
*.tar.gz
*.rar
.emergent/
test_reports/
*.bak
*.tmp
